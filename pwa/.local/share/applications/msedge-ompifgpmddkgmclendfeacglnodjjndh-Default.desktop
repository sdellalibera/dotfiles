#!/usr/bin/env xdg-open
[Desktop Entry]
Version=1.0
Terminal=false
Type=Application
Name=Microsoft Teams (PWA)
MimeType=x-scheme-handler/web+msteams;x-scheme-handler/microsoft-edge;
Exec=/opt/microsoft/msedge/microsoft-edge --profile-directory=Default --app-id=ompifgpmddkgmclendfeacglnodjjndh "--app-url=https://teams.cloud.microsoft/?clientType=pwa" %U
Icon=msedge-ompifgpmddkgmclendfeacglnodjjndh-Default
StartupWMClass=crx__ompifgpmddkgmclendfeacglnodjjndh
